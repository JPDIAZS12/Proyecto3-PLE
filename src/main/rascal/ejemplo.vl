defmodule MiModulo
  defspace Enteros end
  defspace Naturales < Enteros end

  defoperator suma : Integer -> Boolean end

  defvar x : Integer y : Boolean end

  defrule (suma x) -> (suma y) end

  defstruct MiLista : Enteros
    1 : Integer
    true : Boolean
    'a' : Char
    "hola" : String
  end
end